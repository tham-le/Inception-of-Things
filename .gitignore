# ===== VAGRANT =====
# Vagrant machine state
.vagrant/
*.log
vagrant_ansible_inventory_*
.vagrant/
*.log
node-token
k3s.yaml
/tmp/
# Vagrant boxes (can be re-downloaded)
*.box

# SSH keys generated by Vagrant
vagrant_private_key
.vagrant.d/

# ===== KUBERNETES =====
# kubectl config files (may contain sensitive data)
kubeconfig*
*.kubeconfig
config

# Kubernetes secrets and sensitive manifests
*secret*.yaml
*secret*.yml
secrets/

# Helm charts cache and packages
charts/*.tgz
.helm/

# K3s token files
node-token
server-token
k3s-token

# ===== DOCKER =====
# Docker compose override files
docker-compose.override.yml
docker-compose.override.yaml

# ===== ARGOCD =====
# ArgoCD initial admin password
argocd-initial-admin-secret*
argocd-secret*

# ArgoCD CLI config
.argocd/

# ===== SSH & CERTIFICATES =====
# SSH keys
*.pem
*.key
*.pub
id_rsa*
id_ed25519*
id_ecdsa*

# SSL/TLS certificates
*.crt
*.cert
*.ca-bundle
*.p12
*.pfx

# ===== LOGS & TEMPORARY FILES =====
# Application logs
*.log
logs/
log/

# Temporary files
*.tmp
*.temp
tmp/
temp/

# Backup files
*.bak
*.backup
*~

# ===== SYSTEM FILES =====
# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon
._*

# Linux
*~
.fuse_hidden*
.Trash-*
.nfs*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ===== EDITOR & IDE FILES =====
# VS Code
.vscode/
*.code-workspace

# Vim
*.swp
*.swo
*~
.netrwhist

# Emacs
*~
\#*\#
/.emacs.desktop
/.emacs.desktop.lock
*.elc

# Sublime Text
*.sublime-project
*.sublime-workspace

# IntelliJ IDEA
.idea/
*.iml
*.iws
*.ipr

# ===== BUILD & CACHE =====
# Node.js (if any custom apps)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Python (if any Python scripts)
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
.venv/

# Go (if any Go applications)
*.exe
*.exe~
*.dll
*.so
*.dylib
vendor/

# ===== PROJECT SPECIFIC =====
# Custom installation scripts output
install.log
setup.log

# Database files (if any local DBs)
*.db
*.sqlite
*.sqlite3

# Environment variables
.env
.env.local
.env.production
.env.test

# Custom configuration overrides
local.conf
override.conf
custom.yaml
custom.yml

# Terraform (if used in bonus)
*.tfstate
*.tfstate.*
.terraform/
.terraform.lock.hcl

# Ansible (if used)
*.retry
.ansible/

# ===== ALLOWED FILES =====
# Force include important config files that might be ignored by other rules
!confs/
!scripts/
!Vagrantfile
!*.yaml
!*.yml
!README.md
!.gitignore

# But still ignore sensitive configs
confs/*secret*
confs/*password*
confs/*token*
scripts/*secret*
scripts/*password*
scripts/*token*